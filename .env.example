# Copy this file to .env.local (Vite auto-loads it, and it's already in .gitignore)
# and fill in real values. Never commit .env.local — only this .example file is tracked.
#
# Only variables prefixed VITE_ are exposed to the browser bundle by Vite — that means
# ONLY public/anon-safe keys belong here. Anything secret (Resend API key, Supabase
# service_role key) must NEVER go in this file — see the note at the bottom for where
# those actually live instead.

# --- Supabase (Settings -> API in your Supabase project dashboard) ---
# Project URL, e.g. https://abcdefghij.supabase.co
VITE_SUPABASE_URL=

# The "publishable" key (Supabase's current name for what used to be called the
# "anon" key) — safe to expose client-side by design, this is what Supabase's Row
# Level Security is for. Do NOT use the "secret"/"service_role" key here.
VITE_SUPABASE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------
# Secrets that do NOT go in this file, and where they actually belong:
#
# - Supabase service_role key: only used inside a Supabase Edge Function
#   (server-side), set via `supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...`
#   — never in client code, never in this .env file.
# - Resend API key: also only used server-side (inside the Edge Function that
#   sends auth emails, or configured directly as Supabase's custom SMTP
#   provider in Supabase Dashboard -> Auth -> Email -> SMTP Settings).
# - Cloudflare API token / Account ID: not an app secret at all — it's a
#   deploy-time credential, stored as encrypted GitHub Actions repo secrets
#   (CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID), used only by
#   .github/workflows/deploy.yml to publish the built site.
